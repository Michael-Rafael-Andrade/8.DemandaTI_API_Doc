{
  "swagger": "2.0",
  "info": {
    "title": "DemandasTI API",
    "version": "1.0.0",
    "description": "API REST para gerenciamento de demandas de TI com autenticação JWT"
  },
  "host": "localhost:3000",
  "basePath": "/",
  "schemes": [
    "http"
  ],
  "securityDefinitions": {
    "BearerAuth": {
      "type": "apiKey",
      "in": "header",
      "name": "Authorization",
      "description": "Informe o token JWT no formato: Bearer <token>"
    }
  },
  "paths": {
    "/": {
      "get": {
        "summary": "Retorna informações gerais da API",
        "description": "",
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/servicos": {
      "get": {
        "tags": [
          "Index"
        ],
        "summary": "Lista os serviços disponíveis na API",
        "description": "",
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/usuarios/cadastro": {
      "post": {
        "tags": [
          "Usuarios"
        ],
        "summary": "Cadastra um novo usuário",
        "description": "",
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "schema": {
              "type": "object",
              "properties": {
                "nome": {
                  "example": "any"
                },
                "email": {
                  "example": "any"
                },
                "senha": {
                  "example": "any"
                }
              }
            }
          }
        ],
        "responses": {
          "201": {
            "description": "Created",
            "schema": {
              "$ref": "#/definitions/UsuarioCriado"
            }
          },
          "400": {
            "description": "Dados inválidos ou e-mail já cadastrado"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      }
    },
    "/api/usuarios/login": {
      "post": {
        "tags": [
          "Usuarios"
        ],
        "summary": "Autentica o usuário e retorna um token JWT",
        "description": "",
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/LoginUsuario"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          },
          "400": {
            "description": "Bad Request"
          },
          "401": {
            "description": "Credenciais inválidas"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      }
    },
    "/api/demandas/": {
      "get": {
        "tags": [
          "Demandas"
        ],
        "summary": "Lista todas as demandas",
        "description": "",
        "parameters": [
          {
            "name": "status",
            "in": "query",
            "type": "string",
            "enum": [
              "pendente",
              "em_andamento",
              "concluido"
            ],
            "description": "Filtra pelo status"
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          },
          "500": {
            "description": "Internal Server Error"
          }
        },
        "security": [
          {
            "BearerAuth": []
          }
        ]
      },
      "post": {
        "tags": [
          "Demandas"
        ],
        "summary": "Cria uma nova demanda",
        "description": "",
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/NovaDemanda"
            }
          }
        ],
        "responses": {
          "201": {
            "description": "Created"
          },
          "400": {
            "description": "Bad Request"
          },
          "500": {
            "description": "Internal Server Error"
          }
        },
        "security": [
          {
            "BearerAuth": []
          }
        ]
      }
    },
    "/api/demandas/{id}": {
      "get": {
        "tags": [
          "Demandas"
        ],
        "summary": "Retorna uma demanda pelo ID",
        "description": "",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "integer",
            "description": "ID da demanda"
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          },
          "400": {
            "description": "Bad Request"
          },
          "404": {
            "description": "Not Found"
          },
          "500": {
            "description": "Internal Server Error"
          }
        },
        "security": [
          {
            "BearerAuth": []
          }
        ]
      },
      "put": {
        "tags": [
          "Demandas"
        ],
        "summary": "Atualiza uma demanda existente",
        "description": "",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "integer",
            "description": "ID da demanda"
          },
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/AtualizaDemanda"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          },
          "400": {
            "description": "Bad Request"
          },
          "404": {
            "description": "Not Found"
          },
          "500": {
            "description": "Internal Server Error"
          }
        },
        "security": [
          {
            "BearerAuth": []
          }
        ]
      },
      "delete": {
        "tags": [
          "Demandas"
        ],
        "summary": "Remove uma demanda",
        "description": "",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "type": "integer",
            "description": "ID da demanda"
          }
        ],
        "responses": {
          "204": {
            "description": "No Content"
          },
          "400": {
            "description": "Bad Request"
          },
          "404": {
            "description": "Not Found"
          },
          "500": {
            "description": "Internal Server Error"
          }
        },
        "security": [
          {
            "BearerAuth": []
          }
        ]
      }
    }
  },
  "definitions": {
    "NovoUsuario": {
      "type": "object",
      "properties": {
        "nome": {
          "type": "string",
          "example": "João Silva"
        },
        "email": {
          "type": "string",
          "example": "joao@email.com"
        },
        "senha": {
          "type": "string",
          "example": "senha123"
        }
      },
      "required": [
        "nome",
        "email",
        "senha"
      ]
    },
    "UsuarioCriado": {
      "type": "object",
      "properties": {
        "id": {
          "type": "number",
          "example": 1
        },
        "nome": {
          "type": "string",
          "example": "João Silva"
        },
        "email": {
          "type": "string",
          "example": "joao@email.com"
        },
        "perfil": {
          "type": "string",
          "example": "usuaio"
        }
      }
    },
    "LoginUsuario": {
      "type": "object",
      "properties": {
        "email": {
          "type": "string",
          "example": "joao@email.com"
        },
        "senha": {
          "type": "string",
          "example": "senha123"
        }
      },
      "required": [
        "email",
        "senha"
      ]
    },
    "LoginResposta": {
      "type": "object",
      "properties": {
        "token": {
          "type": "string",
          "example": ""
        },
        "usuario": {
          "type": "object",
          "properties": {
            "id": {
              "type": "number",
              "example": 1
            },
            "nome": {
              "type": "string",
              "example": "João Silva"
            },
            "email": {
              "type": "string",
              "example": "joao@email.com"
            },
            "perfil": {
              "type": "string",
              "example": "usuario"
            }
          }
        }
      }
    },
    "Demanda": {
      "type": "object",
      "properties": {
        "id": {
          "type": "number",
          "example": 1
        },
        "titulo": {
          "type": "string",
          "example": "Instalar impressora"
        },
        "texto": {
          "type": "string",
          "example": "Necessário instalar driver da impressora HP"
        },
        "urgencia": {
          "type": "number",
          "example": 3
        },
        "status": {
          "type": "string",
          "example": "pendente"
        },
        "usuario_id": {
          "type": "number",
          "example": 1
        },
        "criada_em": {
          "type": "string",
          "example": "2026-05-27T10:00:00.000Z"
        },
        "atualizada_em": {
          "type": "string",
          "example": "2026-05-27T10:00:00.000Z"
        }
      }
    },
    "NovaDemanda": {
      "type": "object",
      "properties": {
        "titulo": {
          "type": "string",
          "example": "Instala impressora"
        },
        "texto": {
          "type": "string",
          "example": "Necessário instalar driver da impressora HP"
        },
        "urgencia": {
          "type": "number",
          "example": 3
        }
      },
      "required": [
        "titulo",
        "texto",
        "urgencia"
      ]
    },
    "AtualizarDemanda": {
      "type": "object",
      "properties": {
        "titulo": {
          "type": "string",
          "example": "instalar impressora"
        },
        "texto": {
          "type": "string",
          "example": "Driver atualizado"
        },
        "urgencia": {
          "type": "number",
          "example": 2
        },
        "status": {
          "type": "string",
          "example": "em_andamento"
        }
      }
    }
  }
}